rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Ownership lookup: cameraClaims/{cameraDeviceId} is function-written only
    // (see match block below) but rules may still `get()`/`exists()` it to
    // scope access on other collections to the linked Home (uid) and/or
    // linked Camera (cameraAuthUid) identities.
    function claimPath(cameraDeviceId) {
      return /databases/$(database)/documents/cameraClaims/$(cameraDeviceId);
    }

    function claimExists(cameraDeviceId) {
      return exists(claimPath(cameraDeviceId));
    }

    function claimData(cameraDeviceId) {
      return get(claimPath(cameraDeviceId)).data;
    }

    function isOwnerUid(cameraDeviceId) {
      return request.auth != null &&
        claimExists(cameraDeviceId) &&
        request.auth.uid == claimData(cameraDeviceId).uid;
    }

    function isCameraUid(cameraDeviceId) {
      return request.auth != null &&
        claimExists(cameraDeviceId) &&
        request.auth.uid == claimData(cameraDeviceId).cameraAuthUid;
    }

    function isLinkedIdentity(cameraDeviceId) {
      return isOwnerUid(cameraDeviceId) || isCameraUid(cameraDeviceId);
    }

    // webrtcSessions field validation — kept close to the schema described
    // at cameraLinks/{cameraDeviceId}/webrtcSessions/{sessionId} so the
    // bounds below aren't a mystery divorced from the contract they guard.
    function isValidStatus(status) {
      return status in [
        "waiting_for_offer", "waiting_for_answer", "connecting",
        "connected", "completed", "failed"
      ];
    }

    // SDP blobs run a few KB in practice; 10000 chars is generous headroom
    // without allowing an unbounded payload.
    function isValidSdp(sdp) {
      return sdp == null || (sdp is string && sdp.size() > 0 && sdp.size() <= 10000);
    }

    function isValidOfferType(offerType) {
      return offerType == null || offerType == "offer";
    }

    function isValidAnswerType(answerType) {
      return answerType == null || answerType == "answer";
    }

    function isValidExpiresAt(expiresAt) {
      return expiresAt is timestamp && expiresAt > request.time;
    }

    // A single ICE candidate line is well under a few hundred bytes in
    // practice; 2000 chars bounds it far above real-world size without
    // allowing an arbitrary payload.
    function isValidCandidate(data) {
      return data.keys().hasOnly(["sdpMid", "sdpMLineIndex", "candidate", "createdAt"]) &&
        (data.sdpMid == null || (data.sdpMid is string && data.sdpMid.size() <= 256)) &&
        data.sdpMLineIndex is int &&
        data.sdpMLineIndex >= 0 &&
        data.candidate is string &&
        data.candidate.size() > 0 &&
        data.candidate.size() <= 2000 &&
        data.createdAt is timestamp;
    }

    // users: own user can read; all writes go through Functions (admin SDK)
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;

      match /cameraDevices/{cameraDeviceId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // cameraClaims: Functions (admin SDK) only — no client access.
    // Still readable from within rules via get()/exists() above (that bypasses
    // these allow rules) to power ownership checks elsewhere.
    match /cameraClaims/{cameraDeviceId} {
      allow read, write: if false;
    }

    // cameraPairingSessions: Functions (admin SDK) only — no client access.
    // Clients never read sessions; all validation happens server-side in
    // createCameraPairingSession/claimCameraForUser.
    match /cameraPairingSessions/{pairingId} {
      allow read, write: if false;
    }

    // cameraLinks: only the linked Home (uid) or linked Camera (cameraAuthUid)
    // identity for that specific cameraDeviceId — never "any authenticated user".
    match /cameraLinks/{cameraDeviceId} {
      allow read: if isLinkedIdentity(cameraDeviceId);

      // Parent doc: written by the Home App's ensureParentDocument() as
      // convenience metadata. No Cloud Function reads this document (only
      // its subcollections, which don't require a parent doc to exist), so
      // this is a client-only, non-authoritative mirror. Restrict to the
      // linked Home owner and to exactly the fields the Home App writes, so
      // it can't be used to smuggle arbitrary data onto this path. Assumes
      // ensureParentDocument() runs after claimCameraForUser has succeeded
      // (cameraClaims must already exist) — if the Home App calls it earlier
      // in the pairing flow, this write will be denied and the app needs to
      // sequence it after claim success instead.
      allow create, update: if isOwnerUid(cameraDeviceId) &&
        request.resource.data.keys().hasOnly(["cameraDeviceId", "homeDeviceId", "updatedAt"]) &&
        request.resource.data.cameraDeviceId == cameraDeviceId;
      allow delete: if false;

      // pairingState: written only by createCameraPairingSession (pre-claim
      // ownership field only) and claimCameraForUser/releaseCamera*
      // functions (post-claim state) via Admin SDK — never by clients.
      // Clients may read it to detect pairing completion/unpair:
      //  - Pre-claim (no cameraClaims doc yet): only the Camera identity
      //    that itself called createCameraPairingSession may read, proven by
      //    matching request.auth.uid against the cameraAuthUid the function
      //    recorded on this same doc at session-creation time — not by mere
      //    knowledge of cameraDeviceId.
      //  - Post-claim: either linked identity (Home owner or Camera) via
      //    cameraClaims, same as every other subcollection here.
      match /pairingState/{document} {
        allow read: if request.auth != null &&
          (
            isLinkedIdentity(cameraDeviceId) ||
            (resource != null && resource.data.cameraAuthUid == request.auth.uid)
          );
        allow write: if false;
      }

      // commands: Home creates commands for its linked Camera to execute;
      // Camera reads pending commands and updates them (e.g. to record
      // completion). Neither role may act once cameraClaims no longer
      // exists (e.g. immediately after unpair), since isOwnerUid/isCameraUid
      // both depend on that claim doc still being present.
      //
      // Field contract below is taken from the actual client code, not
      // invented:
      //  - Home App (DeleteCameraScreen.kt) creates the UNPAIR shape as
      //    {type, status: "pending", createdAt, createdBy, homeDeviceId,
      //    cameraDeviceId} — no other field is ever written on create.
      //  - Home App (PlacementImageTransferInitiator) creates CONFIRM_PLACEMENT
      //    with those same base fields plus sessionId/transferId, which tie the
      //    command to the webrtcSessions doc and command doc id created for the
      //    same placement-image transfer. UNPAIR never carries these two fields.
      //  - Camera App (PairingFirestoreManager.completeCommand) only ever
      //    calls .update("status", "completed", "completedAt", <server ts>)
      //    — no other field or status transition is ever performed.
      function isValidTransferRef(value) {
        return value is string && value.size() > 0;
      }

      match /commands/{commandId} {
        allow read: if isLinkedIdentity(cameraDeviceId);

        allow create: if isOwnerUid(cameraDeviceId) &&
          request.resource.data.type in ["UNPAIR", "CONFIRM_PLACEMENT"] &&
          request.resource.data.status == "pending" &&
          request.resource.data.createdBy == request.auth.uid &&
          request.resource.data.cameraDeviceId == cameraDeviceId &&
          request.resource.data.homeDeviceId is string &&
          (
            (request.resource.data.type == "CONFIRM_PLACEMENT" &&
              request.resource.data.keys().hasOnly([
                "type", "status", "createdAt", "createdBy", "homeDeviceId", "cameraDeviceId",
                "sessionId", "transferId"
              ]) &&
              isValidTransferRef(request.resource.data.sessionId) &&
              isValidTransferRef(request.resource.data.transferId)) ||
            (request.resource.data.type == "UNPAIR" &&
              request.resource.data.keys().hasOnly([
                "type", "status", "createdAt", "createdBy", "homeDeviceId", "cameraDeviceId"
              ]))
          );

        // Camera may only flip status pending -> completed and stamp
        // completedAt; every other field (type, createdBy, createdAt,
        // homeDeviceId, cameraDeviceId) is immutable from the Camera's side,
        // and no new field may be introduced.
        allow update: if isCameraUid(cameraDeviceId) &&
          resource.data.status == "pending" &&
          request.resource.data.status == "completed" &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "completedAt"]);

        allow delete: if isOwnerUid(cameraDeviceId);
      }

      // notificationSettings: Home-owner preference toggles (e.g. mute a
      // notification type). Only the linked Home may read/write its own.
      match /notificationSettings/{type} {
        allow read, write: if isOwnerUid(cameraDeviceId);
      }

      // notificationQueue: function-only. Clients (including the linked
      // Camera) must never create these documents directly —
      // sendNotificationOnCreate fires on any document created here, so
      // allowing client writes would let anyone spoof a push notification.
      // The Camera App reports events via the submitCameraEvent callable
      // instead, which writes here server-side (Admin SDK bypasses these
      // rules) through the same handleCameraEvent logic used by
      // enqueueCameraStatusNotification.
      match /notificationQueue/{eventId} {
        allow read, write: if false;
      }

      // notificationTarget: holds the Home's FCM token (`home` doc). Only
      // the linked Home identity may read or write its own token — this
      // must never be readable by other authenticated users or writable by
      // the linked Camera.
      match /notificationTarget/{document} {
        allow read, write: if isOwnerUid(cameraDeviceId);
      }

      // activityEvents: function-written activity feed (via handleCameraEvent,
      // called from enqueueCameraStatusNotification and submitCameraEvent).
      // Either linked identity may read; the Camera no longer writes here
      // directly — only functions (Admin SDK) may write.
      match /activityEvents/{eventId} {
        allow read: if isLinkedIdentity(cameraDeviceId);
        allow write: if false;
      }

      // webrtcSessions: minimal WebRTC signaling contract for a single
      // Camera <-> Home session (PLACEMENT_IMAGE preview and ACTIVITY_ZONE
      // transfer). Firestore scaffolding only — this collection carries
      // offer/answer/ICE signaling metadata alone; the ACTIVITY_ZONE
      // purpose never puts zone coordinates here, since request.resource.data
      // is closed to exactly the keys listed below (no free-form payload
      // field exists for either purpose to smuggle app data through).
      //
      // Lifecycle: Home creates the session in "waiting_for_offer" with no
      // SDP set yet, then updates it in place to attach its own offer
      // (status -> "waiting_for_answer"). The linked Camera reads the
      // session and updates it in place to attach its answer and advance
      // status further. Identity fields (cameraDeviceId, homeDeviceId,
      // createdBy) and purpose are fixed at creation and immutable after;
      // each side may only ever touch the fields it owns.
      match /webrtcSessions/{sessionId} {
        allow read: if isLinkedIdentity(cameraDeviceId);

        allow create: if isOwnerUid(cameraDeviceId) &&
          request.resource.data.keys().hasOnly([
            "cameraDeviceId", "homeDeviceId", "createdBy", "purpose", "status",
            "offerSdp", "offerType", "answerSdp", "answerType",
            "createdAt", "updatedAt", "expiresAt"
          ]) &&
          request.resource.data.cameraDeviceId == cameraDeviceId &&
          request.resource.data.homeDeviceId is string &&
          request.resource.data.createdBy == request.auth.uid &&
          request.resource.data.purpose in ["PLACEMENT_IMAGE", "ACTIVITY_ZONE"] &&
          request.resource.data.status == "waiting_for_offer" &&
          request.resource.data.offerSdp == null &&
          request.resource.data.offerType == null &&
          request.resource.data.answerSdp == null &&
          request.resource.data.answerType == null &&
          request.resource.data.createdAt is timestamp &&
          request.resource.data.updatedAt is timestamp &&
          isValidExpiresAt(request.resource.data.expiresAt);

        // Home may only advance status and attach its own offer; the
        // answer fields and every identity/purpose field stay untouched.
        allow update: if isOwnerUid(cameraDeviceId) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["status", "offerSdp", "offerType", "updatedAt"]) &&
          isValidStatus(request.resource.data.status) &&
          isValidSdp(request.resource.data.offerSdp) &&
          isValidOfferType(request.resource.data.offerType) &&
          request.resource.data.updatedAt is timestamp;

        // Camera may only advance status and attach its own answer; the
        // offer fields and every identity/purpose field stay untouched.
        allow update: if isCameraUid(cameraDeviceId) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["status", "answerSdp", "answerType", "updatedAt"]) &&
          isValidStatus(request.resource.data.status) &&
          isValidSdp(request.resource.data.answerSdp) &&
          isValidAnswerType(request.resource.data.answerType) &&
          request.resource.data.updatedAt is timestamp;

        allow delete: if false;

        // ICE candidates are append-only and split by origin so each side
        // can only ever write its own — never edit or delete once sent.
        // Both linked identities may read both subcollections: each side
        // needs to see the other's candidates to complete the exchange.
        match /homeCandidates/{candidateId} {
          allow read: if isLinkedIdentity(cameraDeviceId);
          allow create: if isOwnerUid(cameraDeviceId) &&
            isValidCandidate(request.resource.data);
          allow update, delete: if false;
        }

        match /cameraCandidates/{candidateId} {
          allow read: if isLinkedIdentity(cameraDeviceId);
          allow create: if isCameraUid(cameraDeviceId) &&
            isValidCandidate(request.resource.data);
          allow update, delete: if false;
        }
      }

      // Deny any other/future subcollection by default (least privilege)
      // instead of the previous catch-all "any authenticated user" rule.
      match /{subcollection}/{document=**} {
        allow read, write: if false;
      }
    }
  }
}

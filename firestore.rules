rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users: own user can read; all writes go through Functions (admin SDK)
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;

      match /cameraDevices/{cameraDeviceId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // cameraClaims: Functions (admin SDK) only — no client access
    match /cameraClaims/{cameraDeviceId} {
      allow read, write: if false;
    }

    // cameraPairingSessions: Functions (admin SDK) only — no client access
    // Clients never read sessions; all validation happens server-side in claimCameraForUser
    match /cameraPairingSessions/{pairingId} {
      allow read, write: if false;
    }

    // cameraLinks: camera and home apps read/write their own data
    match /cameraLinks/{cameraDeviceId} {
      allow read, write: if request.auth != null;

      // pairingState: written only by claimCameraForUser via Admin SDK.
      // Clients (Camera App) may read it to detect pairing completion but never write it.
      match /pairingState/{document} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      match /{subcollection}/{document} {
        allow read, write: if request.auth != null && subcollection != "pairingState";
      }
    }
  }
}
